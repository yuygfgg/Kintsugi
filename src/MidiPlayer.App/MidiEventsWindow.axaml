<Window
    x:Class="MidiPlayer.App.MidiEventsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MidiPlayer.App.Models"
    mc:Ignorable="d"
    Width="800"
    Height="500"
    MinWidth="500"
    MinHeight="300"
    Title="MIDI Event Browser"
    WindowStartupLocation="CenterScreen"
    Classes="appWindow">
  <Grid RowDefinitions="Auto,Auto,*" Margin="16">
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <StackPanel Spacing="4">
        <TextBlock Text="MIDI EVENT BROWSER" FontSize="16" FontWeight="Bold" Classes="accent" />
        <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding FilePath}" FontSize="11" Classes="hint" TextTrimming="CharacterEllipsis" />
      </StackPanel>

      <Border Grid.Column="1" Classes="pill" Padding="10,4" VerticalAlignment="Top">
        <TextBlock Text="{Binding SummaryText}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Classes="secondaryAccent" />
      </Border>
    </Grid>

    <Border Grid.Row="1" Classes="panel" Margin="0,0,0,12" Padding="0">
      <Grid ColumnDefinitions="68,118,118,84,72,78,78,*" Margin="12,8">
        <TextBlock Text="Track" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
        <TextBlock Grid.Column="1" Text="Position" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
        <TextBlock Grid.Column="2" Text="Time" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
        <TextBlock Grid.Column="3" Text="Status" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
        <TextBlock Grid.Column="4" Text="Channel" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
        <TextBlock Grid.Column="5" Text="Number" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
        <TextBlock Grid.Column="6" Text="Value" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
        <TextBlock Grid.Column="7" Text="Length / Summary" FontSize="11" FontWeight="Bold" Classes="accentMuted" />
      </Grid>
    </Border>

    <Border Grid.Row="2" Classes="panel" ClipToBounds="True">
      <Grid>
        <ListBox x:Name="RowsListBox" ItemsSource="{Binding Rows}" IsVisible="{Binding !IsEmpty}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:MidiEventBrowserRow">
              <Border ToolTip.Tip="{Binding ToolTipText}"
                      Background="{Binding BackgroundBrush}">
                <Grid ColumnDefinitions="68,118,118,84,72,78,78,*" Margin="12,0" Height="32">
                  <TextBlock Text="{Binding TrackText}" VerticalAlignment="Center" Classes="mono" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" />
                  <TextBlock Grid.Column="1" Text="{Binding LocationText}" VerticalAlignment="Center" Classes="mono" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" />
                  <TextBlock Grid.Column="2" Text="{Binding TimeText}" VerticalAlignment="Center" Classes="mono" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" />
                  <TextBlock Grid.Column="3" Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" />
                  <TextBlock Grid.Column="4" Text="{Binding ChannelText}" VerticalAlignment="Center" Classes="mono" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" />
                  <TextBlock Grid.Column="5" Text="{Binding NumberText}" VerticalAlignment="Center" Classes="mono" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" />
                  <TextBlock Grid.Column="6" Text="{Binding ValueText}" VerticalAlignment="Center" Classes="mono" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" />
                  <TextBlock Grid.Column="7"
                             Text="{Binding SummaryText}"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{Binding ForegroundBrush}"
                             FontWeight="{Binding FontWeight}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel IsVisible="{Binding IsEmpty}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
          <TextBlock Text="{Binding EmptyStateTitle}"
                     FontSize="14"
                     FontWeight="Bold"
                     Classes="secondaryAccent"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{Binding EmptyStateText}"
                     FontSize="12"
                     Classes="hint"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
