<Window
    x:Class="MidiPlayer.App.AudioPluginPickerWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Load Audio Plug-in"
    Classes="appWindow"
    Width="760"
    Height="560"
    MinWidth="620"
    MinHeight="420"
    WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20" RowSpacing="16">
    <StackPanel Spacing="6">
      <TextBlock Text="Load VST3 / Audio Unit" FontSize="24" FontWeight="SemiBold" Classes="accent" />
    </StackPanel>

    <StackPanel Grid.Row="1" Spacing="8">
      <TextBlock Text="Bundle Path" FontWeight="SemiBold" />
      <TextBox Text="{Binding ManualPath, Mode=TwoWay}"
               Watermark="/Library/Audio/Plug-Ins/VST3/YourPlugin.vst3" />
      <TextBlock Classes="hint"
                 Text="Paste a full .vst3 or .component bundle path, or pick one from the detected list below." />
    </StackPanel>

    <Border Grid.Row="2" Classes="panel" Padding="0">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto" Margin="14,14,14,10" ColumnSpacing="12">
          <TextBlock Text="Detected Plug-ins" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="actionBtn" Content="Refresh" Click="OnRefreshClicked" Padding="14,6" />
        </Grid>

        <ListBox Grid.Row="1"
                 Margin="10,0,10,10"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemsSource="{Binding AvailablePlugins}"
                 SelectedItem="{Binding SelectedPlugin, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="panel" Margin="0,0,0,8" Padding="12">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="6">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Classes="secondaryAccent" />
                  <Border Grid.Column="1" Classes="accentPill" Padding="10,3">
                    <TextBlock Text="{Binding FormatLabel}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Theme.ToggleActiveForegroundBrush}" />
                  </Border>
                  <TextBlock Grid.Row="1"
                             Text="{Binding Path}"
                             Classes="hint"
                             MaxWidth="620"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
      <TextBlock Text="{Binding StatusText}"
                 Classes="hint"
                 VerticalAlignment="Center"
                 MaxWidth="460"
                 TextTrimming="CharacterEllipsis"
                 ToolTip.Tip="{Binding StatusText}" />
      <Button Grid.Column="1" Classes="secondary" Content="Cancel" Click="OnCancelClicked" Padding="16,8" />
      <Button Grid.Column="2" Classes="actionBtn" Content="Load Plug-in" Click="OnAcceptClicked" IsEnabled="{Binding CanConfirm}" Padding="18,8" />
    </Grid>
  </Grid>
</Window>
