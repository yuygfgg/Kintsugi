<Window
    x:Class="MidiPlayer.App.AudioPluginPickerWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Load Audio Plug-in"
    Width="760"
    Height="560"
    MinWidth="620"
    MinHeight="420"
    WindowStartupLocation="CenterOwner"
    Background="#101010">
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#E0E0E0" />
    </Style>
    <Style Selector="TextBlock.hint">
      <Setter Property="Foreground" Value="#7A8A9A" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Focusable" Value="False" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20" RowSpacing="16">
    <StackPanel Spacing="6">
      <TextBlock Text="Load VST3 / Audio Unit" FontSize="24" FontWeight="SemiBold" />
      <TextBlock Classes="hint"
                 Text="macOS treats plug-in bundles as packages, so this browser scans the standard VST3 and Components folders instead of relying on the system file picker. VST2 bundles are not scanned in this build." />
    </StackPanel>

    <StackPanel Grid.Row="1" Spacing="8">
      <TextBlock Text="Bundle Path" FontWeight="SemiBold" />
      <TextBox Text="{Binding ManualPath, Mode=TwoWay}"
               Watermark="/Library/Audio/Plug-Ins/VST3/YourPlugin.vst3"
               Background="#171717"
               BorderBrush="#2F2F2F"
               Foreground="#E0E0E0" />
      <TextBlock Classes="hint"
                 Text="Paste a full .vst3 or .component bundle path, or pick one from the detected list below." />
    </StackPanel>

    <Border Grid.Row="2"
            Background="#151515"
            BorderBrush="#2F2F2F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto" Margin="14,14,14,10" ColumnSpacing="12">
          <TextBlock Text="Detected Plug-ins" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Content="Refresh"
                  Click="OnRefreshClicked"
                  Background="#202A36"
                  Foreground="#DCEEFF"
                  BorderBrush="#3A74B0"
                  BorderThickness="1"
                  Padding="14,6" />
        </Grid>

        <ListBox Grid.Row="1"
                 Margin="10,0,10,10"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemsSource="{Binding AvailablePlugins}"
                 SelectedItem="{Binding SelectedPlugin, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,8"
                      Padding="12"
                      Background="#111111"
                      BorderBrush="#262626"
                      BorderThickness="1"
                      CornerRadius="6">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="6">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#DCEEFF" />
                  <Border Grid.Column="1"
                          Background="#13283E"
                          BorderBrush="#3A74B0"
                          BorderThickness="1"
                          CornerRadius="999"
                          Padding="10,3">
                    <TextBlock Text="{Binding FormatLabel}" FontSize="11" FontWeight="Bold" Foreground="#DCEEFF" />
                  </Border>
                  <TextBlock Grid.Row="1"
                             Text="{Binding Path}"
                             Classes="hint"
                             MaxWidth="620"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
      <TextBlock Text="{Binding StatusText}"
                 Classes="hint"
                 VerticalAlignment="Center"
                 MaxWidth="460"
                 TextTrimming="CharacterEllipsis"
                 ToolTip.Tip="{Binding StatusText}" />
      <Button Grid.Column="1"
              Content="Cancel"
              Click="OnCancelClicked"
              Background="#1C1C1C"
              Foreground="#E0E0E0"
              BorderBrush="#333333"
              BorderThickness="1"
              Padding="16,8" />
      <Button Grid.Column="2"
              Content="Load Plug-in"
              Click="OnAcceptClicked"
              IsEnabled="{Binding CanConfirm}"
              Background="#214B75"
              Foreground="#DCEEFF"
              BorderBrush="#4A90E2"
              BorderThickness="1"
              Padding="18,8" />
    </Grid>
  </Grid>
</Window>
