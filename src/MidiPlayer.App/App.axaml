<Application
    x:Class="MidiPlayer.App.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Name="Kintsugi Midi Player">
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About Kintsugi Midi Player..." Click="OnAboutRequested" />
            <NativeMenuItem Header="Preferences..." Click="OnPreferencesRequested" />
        </NativeMenu>
    </NativeMenu.Menu>
</Application>
