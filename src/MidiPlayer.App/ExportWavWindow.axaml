<Window
    x:Class="MidiPlayer.App.ExportWavWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Kintsugi Midi Player Export"
    Classes="appWindow"
    Width="480"
    MinHeight="380"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    CanResize="False">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="18" Margin="28">
    <TextBlock Text="Export Audio" FontSize="24" FontWeight="SemiBold" Classes="accent" />

    <Border Grid.Row="1" Classes="panel" Padding="16">
      <StackPanel Spacing="8">
        <TextBlock Text="CURRENT TRACK" FontSize="10" FontWeight="Bold" Classes="dim" />
        <TextBlock Text="{Binding TrackDisplayName}" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Text="{Binding SoundFontDisplayName}" Classes="hint" />
        <TextBlock Text="{Binding PlaybackModifiersSummary}" Classes="hint" />
        <TextBlock Text="{Binding FormatSummary}" FontSize="12" FontWeight="SemiBold" Classes="secondaryAccent" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="16">
      <StackPanel x:Name="FormatPanel" Spacing="8">
        <TextBlock Text="Format" FontWeight="SemiBold" />
        <ComboBox x:Name="FormatComboBox" SelectionChanged="OnFormatChanged" />
      </StackPanel>

      <StackPanel x:Name="SampleRatePanel" Grid.Column="1" Spacing="8">
        <TextBlock Text="Sample Rate" FontWeight="SemiBold" />
        <ComboBox x:Name="SampleRateComboBox" SelectionChanged="OnFormatChanged" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="3" RowDefinitions="Auto,Auto" RowSpacing="14">
      <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
        <StackPanel x:Name="BitDepthPanel" Spacing="8">
          <TextBlock Text="Bit Depth" FontWeight="SemiBold" />
          <ComboBox x:Name="BitDepthComboBox" SelectionChanged="OnFormatChanged" />
        </StackPanel>

        <StackPanel x:Name="OpusBitratePanel" Grid.Column="1" Spacing="8" IsVisible="False">
          <TextBlock Text="Opus Bitrate (kbps)" FontWeight="SemiBold" />
          <TextBox Text="{Binding OpusBitrateDisplay}" />
        </StackPanel>
      </Grid>

      <StackPanel Grid.Row="1" Spacing="14">
        <StackPanel Spacing="8">
          <TextBlock Text="Destination" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBox Text="{Binding OutputPathDisplay}" IsReadOnly="True" />
            <Button Grid.Column="1" Classes="compact" Content="Change..." Click="OnBrowseOutputClicked" />
          </Grid>
        </StackPanel>

        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
          <Border />
          <Button Grid.Column="1" Classes="secondary" Content="Cancel" Width="88" Click="OnCancelClicked" />
          <Button Grid.Column="2" Classes="primary" Content="Export" Width="96" Click="OnExportClicked" />
        </Grid>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
