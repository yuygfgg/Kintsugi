<Window
    x:Class="MidiPlayer.App.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:MidiPlayer.App.Controls"
    Title="Kintsugi Midi Player"
    Width="820"
    Height="560"
    MinWidth="700"
    MinHeight="460"
    WindowStartupLocation="CenterScreen"
    Background="#101010">
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#E0E0E0" />
    </Style>
    <Style Selector="ToolTip">
      <Setter Property="Background" Value="#0D0D0D" />
      <Setter Property="BorderBrush" Value="#303030" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#DCEEFF" />
    </Style>
    <Style Selector="ToolTip TextBlock">
      <Setter Property="Foreground" Value="#DCEEFF" />
    </Style>
    <Style Selector="Button.iconBtn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#333" />
      <Setter Property="Foreground" Value="#C8D7E6" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
    </Style>
    <Style Selector="Button.iconBtn:disabled">
      <Setter Property="Foreground" Value="#8091A2" />
    </Style>
    <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#303030" />
    </Style>
    <Style Selector="Button.actionBtn">
      <Setter Property="Background" Value="#163553" />
      <Setter Property="BorderBrush" Value="#3A74B0" />
      <Setter Property="Foreground" Value="#DCEEFF" />
    </Style>
    <Style Selector="Button.actionBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#214B75" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Focusable" Value="False" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
    <!-- Header -->
    <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,16">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalAlignment="Center" ClipToBounds="True" Margin="0,0,12,0">
        <TextBlock Text="KINTSUGI MIDI PLAYER" FontSize="16" FontWeight="Bold" Foreground="#4A90E2" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding MidiDisplayName}"
                   FontSize="14"
                   FontWeight="Normal"
                   Foreground="#A0A0A0"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <Border Grid.Column="2"
                Background="#171717"
                BorderBrush="#2F2F2F"
                BorderThickness="1"
                CornerRadius="999"
                Padding="8,3"
                VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText}"
                     FontSize="11"
                     Foreground="#888"
                     VerticalAlignment="Center"
                     MaxWidth="180"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding StatusText}" />
        </Border>
      </Grid>
      <Button Grid.Column="1" Click="OnOpenMidiClicked" Classes="iconBtn" FontSize="11" FontWeight="Bold" Margin="0,0,8,0" IsEnabled="{Binding CanOpenMidi}">
        <TextBlock Text="OPEN FILE" Foreground="#C8D7E6" />
      </Button>
      <Button Grid.Column="2" Click="OnExportWavClicked" Classes="iconBtn actionBtn" FontSize="11" FontWeight="Bold" Margin="0,0,8,0" IsEnabled="{Binding CanExport}">
        <TextBlock Text="{Binding ExportButtonText}" Foreground="#DCEEFF" />
      </Button>
      <Button Grid.Column="3" Classes="iconBtn" Click="OnSettingsClicked" ToolTip.Tip="Settings" IsEnabled="{Binding CanOpenSettings}">
        <TextBlock Text="⚙" FontSize="14" />
      </Button>
    </Grid>

    <!-- Channel Monitor -->
    <Border Grid.Row="1"
            Background="#181818"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8"
            Margin="0,0,0,16"
            ClipToBounds="False"
            ZIndex="20">
      <StackPanel Spacing="8">
        <TextBlock Text="CHANNEL ACTIVITY" FontSize="10" FontWeight="Bold" Foreground="#666" />
        <Grid Height="24" ClipToBounds="False">
          <controls:ChannelMonitorControl
              x:Name="ChannelMonitorView"
              Height="24"
              Player="{Binding Player}"
              ChannelMixerRequested="OnChannelMixerRequested" />

          <Canvas
                  x:Name="ChannelMixerPopupHost"
                  Height="24"
                  IsVisible="{Binding IsChannelMixerPopupOpen}"
                  ClipToBounds="False">
            <Grid
                Width="244"
                Height="206"
                Canvas.Left="{Binding ChannelMixerPopupLeft}"
                Canvas.Top="26"
                ZIndex="30">
              <Path
                  Data="{Binding ChannelMixerPopupOutlinePathData}"
                  Fill="#111111"
                  Stroke="#3A74B0"
                  StrokeThickness="1" />

              <StackPanel
                  DataContext="{Binding SelectedChannelMixStrip}"
                  Margin="10,18,10,10"
                  Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Text="{Binding ChannelLabel}" FontSize="11" FontWeight="Bold" Foreground="#DCEEFF" />
                  <TextBlock Grid.Column="1" Text="SEND" FontSize="9" FontWeight="Bold" Foreground="#5D88B4" />
                </Grid>

                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="VOL" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Slider
                        Grid.Column="2"
                        Minimum="0"
                        Maximum="200"
                        Value="{Binding VolumePercent, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset to 100%"
                        DoubleTapped="OnChannelVolumeSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding VolumeText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="REV" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnChannelReverbModeClicked"
                        ToolTip.Tip="{Binding ReverbSendModeToolTip}">
                      <TextBlock Text="{Binding ReverbSendModeLabel}" FontSize="9" FontWeight="Bold" Foreground="#B6D6F8" />
                    </Button>
                    <Slider
                        Grid.Column="2"
                        Minimum="{Binding ReverbSendMinimum}"
                        Maximum="{Binding ReverbSendMaximum}"
                        Value="{Binding ReverbSendValue, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnChannelReverbSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding ReverbSendText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="CHO" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnChannelChorusModeClicked"
                        ToolTip.Tip="{Binding ChorusSendModeToolTip}">
                      <TextBlock Text="{Binding ChorusSendModeLabel}" FontSize="9" FontWeight="Bold" Foreground="#B6D6F8" />
                    </Button>
                    <Slider
                        Grid.Column="2"
                        Minimum="{Binding ChorusSendMinimum}"
                        Maximum="{Binding ChorusSendMaximum}"
                        Value="{Binding ChorusSendValue, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnChannelChorusSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding ChorusSendText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Grid>
          </Canvas>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Piano Roll / Visualizer -->
    <Border Grid.Row="2" Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16" ClipToBounds="True">
      <Grid RowDefinitions="*,Auto">
        <!-- Spectrum Analyzer -->
        <controls:SpectrumControl Player="{Binding Player}" Margin="8" />
        
        <!-- Piano Keyboard -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="8,0,8,8">
          <Button
              Grid.Column="0"
              Classes="iconBtn"
              Width="44"
              Height="96"
              Padding="0"
              Click="OnTransposeDownClicked"
              IsEnabled="{Binding CanAdjustPlaybackModifiers}"
              ToolTip.Tip="Transpose down by one semitone">
            <StackPanel Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="KEY" FontSize="9" FontWeight="Bold" Foreground="#6A8FB4" HorizontalAlignment="Center" />
              <TextBlock Text="−" FontSize="18" FontWeight="Bold" Foreground="#DCEEFF" HorizontalAlignment="Center" />
            </StackPanel>
          </Button>

          <Grid Grid.Column="1" Height="96" RowDefinitions="Auto,*">
            <Border
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,0,0,4"
                Background="#111111CC"
                BorderBrush="#2F2F2F"
                BorderThickness="1"
                CornerRadius="999"
                Padding="10,3">
              <TextBlock Text="{Binding TransposeSemitonesText}"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="#B6D6F8"
                         FontFamily="Courier New" />
            </Border>

            <controls:PianoControl
                Grid.Row="1"
                Height="80"
                Player="{Binding Player}"
                TransposeOffsetSemitones="{Binding TransposeSemitones}" />
          </Grid>

          <Button
              Grid.Column="2"
              Classes="iconBtn"
              Width="44"
              Height="96"
              Padding="0"
              Click="OnTransposeUpClicked"
              IsEnabled="{Binding CanAdjustPlaybackModifiers}"
              ToolTip.Tip="Transpose up by one semitone">
            <StackPanel Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="KEY" FontSize="9" FontWeight="Bold" Foreground="#6A8FB4" HorizontalAlignment="Center" />
              <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="#DCEEFF" HorizontalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>
      </Grid>
    </Border>

    <!-- Transport Controls -->
    <Border Grid.Row="3" Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Padding="16">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Button Grid.Column="0"
            Width="48"
            Height="48"
            CornerRadius="24"
            Background="#4A90E2"
            BorderThickness="0"
            Click="OnPlayPauseClicked"
            IsEnabled="{Binding CanTogglePlayback}"
            Margin="0,0,16,0">
          <TextBlock Text="{Binding PlayPauseIcon}" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{Binding PlayPauseIconMargin}"/>
        </Button>
        
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Text="{Binding PositionText}" FontSize="12" Foreground="#888" FontFamily="Courier New" />
            <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="12" Foreground="#888" FontFamily="Courier New" />
          </Grid>
          <Slider
              x:Name="SeekSlider"
              Minimum="0"
              Maximum="{Binding DurationSeconds}"
              Value="{Binding PositionSeconds, Mode=TwoWay}"
              IsEnabled="{Binding CanSeek}"
              Foreground="#4A90E2" />
        </StackPanel>
        
        <StackPanel Grid.Column="2" Margin="16,0,0,0" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Grid x:Name="GlobalMixerButtonHost" Width="40" Height="40">
              <Button
                  Classes="iconBtn"
                  Width="40"
                  Height="40"
                  Padding="0"
                  CornerRadius="20"
                  Click="OnGlobalMixerClicked"
                  ToolTip.Tip="Master / Return mixer"
                  Background="{Binding GlobalMixerButtonBackground}"
                  BorderBrush="{Binding GlobalMixerButtonBorderBrush}">
                <TextBlock Text="MIX"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{Binding GlobalMixerButtonForeground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Button>

              <Border
                  IsVisible="{Binding IsGlobalMixerPopupOpen}"
                  Width="248"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,-184,0,0"
                  Background="#111111"
                  BorderBrush="#3A74B0"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="MASTER / RETURN" FontSize="10" FontWeight="Bold" Foreground="#DCEEFF" />

                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="VOL" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Slider
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="200"
                        Value="{Binding MasterVolumePercent, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset to 100%"
                        DoubleTapped="OnMasterVolumeSliderDoubleTapped" />
                    <TextBlock Grid.Column="2" Text="{Binding MasterVolumePercentText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="REV" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnGlobalReverbModeClicked"
                        ToolTip.Tip="{Binding GlobalReverbReturnModeToolTip}">
                      <TextBlock Text="{Binding GlobalReverbReturnModeLabel}" FontSize="9" FontWeight="Bold" Foreground="#B6D6F8" />
                    </Button>
                    <Slider
                        Grid.Column="2"
                        Minimum="{Binding GlobalReverbReturnMinimum}"
                        Maximum="{Binding GlobalReverbReturnMaximum}"
                        Value="{Binding GlobalReverbReturnValue, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnReverbSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding GlobalReverbReturnText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="CHO" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnGlobalChorusModeClicked"
                        ToolTip.Tip="{Binding GlobalChorusReturnModeToolTip}">
                      <TextBlock Text="{Binding GlobalChorusReturnModeLabel}" FontSize="9" FontWeight="Bold" Foreground="#B6D6F8" />
                    </Button>
                    <Slider
                        Grid.Column="2"
                        Minimum="{Binding GlobalChorusReturnMinimum}"
                        Maximum="{Binding GlobalChorusReturnMaximum}"
                        Value="{Binding GlobalChorusReturnValue, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnChorusSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding GlobalChorusReturnText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>
            </Grid>

            <Button
                Classes="iconBtn"
                Width="40"
                Height="40"
                Padding="0"
                CornerRadius="20"
                Click="OnLoopClicked"
                ToolTip.Tip="Loop playback"
                Background="{Binding LoopButtonBackground}"
                BorderBrush="{Binding LoopButtonBorderBrush}">
              <Viewbox Width="18" Height="18" Stretch="Uniform">
                <Path Data="M 2 9 A 4 4 0 0 1 6 5 L 16 5 M 13 2 L 16 5 L 13 8 M 16 9 A 4 4 0 0 1 12 13 L 2 13 M 5 10 L 2 13 L 5 16"
                      Stroke="{Binding LoopButtonForeground}"
                      StrokeThickness="1.8"
                      StrokeLineCap="Round"
                      StrokeJoin="Round"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
              </Viewbox>
            </Button>

            <Grid x:Name="SpeedButtonHost" Width="74" Height="40" ClipToBounds="False">
              <Button
                  Width="74"
                  Height="40"
                  Padding="12,6"
                  Click="OnSpeedButtonClicked"
                  IsEnabled="{Binding CanAdjustPlaybackModifiers}"
                  Background="{Binding SpeedButtonBackground}"
                  BorderBrush="{Binding SpeedButtonBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="999">
                <StackPanel Spacing="1">
                  <TextBlock Text="BPM"
                             FontSize="10"
                             FontWeight="Bold"
                             Foreground="{Binding SpeedButtonForeground}"
                             HorizontalAlignment="Right" />
                  <TextBlock Text="{Binding CurrentBpmText}"
                             FontSize="14"
                             Foreground="{Binding SpeedButtonForeground}"
                             HorizontalAlignment="Right"
                             FontFamily="Courier New" />
                </StackPanel>
              </Button>

              <Border
                  IsVisible="{Binding IsSpeedPopupOpen}"
                  ZIndex="20"
                  Width="240"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,-102,0,0"
                  Background="#111111"
                  BorderBrush="#3A74B0"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="TEMPO OVERRIDE" FontSize="10" FontWeight="Bold" Foreground="#DCEEFF" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding PlaybackSpeedPercentText}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#B6D6F8"
                               FontFamily="Courier New" />
                  </Grid>

                  <Slider
                      Minimum="25"
                      Maximum="400"
                      Value="{Binding PlaybackSpeedPercent, Mode=TwoWay}"
                      IsEnabled="{Binding CanAdjustPlaybackModifiers}"
                      Foreground="#4A90E2"
                      SmallChange="1"
                      LargeChange="10"
                      ToolTip.Tip="Override playback speed. Double-click to reset to 100%."
                      DoubleTapped="OnPlaybackSpeedSliderDoubleTapped" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
