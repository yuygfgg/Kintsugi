<Window
    x:Class="MidiPlayer.App.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:MidiPlayer.App.Controls"
    xmlns:models="using:MidiPlayer.App.Models"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
    Title="Kintsugi Midi Player"
    Classes="appWindow"
    Width="820"
    Height="560"
    MinWidth="700"
    MinHeight="460"
    WindowStartupLocation="CenterScreen">
  <Panel>
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalAlignment="Center" ClipToBounds="True" Margin="0,0,12,0">
        <TextBlock Text="KINTSUGI MIDI PLAYER" FontSize="16" FontWeight="Bold" Classes="accent" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding MidiDisplayName}"
                   FontSize="14"
                   FontWeight="Normal"
                   Classes="muted"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <Border Grid.Column="2" Classes="pill" Padding="8,3" VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText}"
                     FontSize="11"
                     Classes="subtle"
                     VerticalAlignment="Center"
                     MaxWidth="180"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding StatusText}" />
        </Border>
      </Grid>
        <Button Grid.Column="1" Classes="iconBtn" FontSize="11" FontWeight="Bold" Margin="0,0,8,0">
          <TextBlock Text="ACTIONS ▾" />
          <Button.Flyout>
            <MenuFlyout>
              <MenuItem Header="Open File..." Click="OnOpenMidiClicked" IsEnabled="{Binding CanOpenMidi}" />
              <MenuItem Header="Export Audio..." Click="OnExportWavClicked" IsEnabled="{Binding CanExport}" />
              <MenuItem Header="Browse Events..." Click="OnBrowseMidiEventsClicked" IsEnabled="{Binding CanBrowseMidiEvents}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
        <Button Grid.Column="2" Classes="iconBtn" Click="OnSettingsClicked" ToolTip.Tip="Settings" IsEnabled="{Binding CanOpenSettings}">
          <TextBlock Text="{Binding SettingsButtonText}" FontSize="14" FontWeight="Bold" />
        </Button>
      </Grid>

    <!-- Channel Monitor -->
    <Border Grid.Row="1" Classes="panel" Padding="8" Margin="0,0,0,16" ClipToBounds="False" ZIndex="20">
      <StackPanel Spacing="8">
        <TextBlock Text="CHANNEL ACTIVITY" FontSize="10" FontWeight="Bold" Classes="dim" />
        <Grid Height="24" ClipToBounds="False">
          <controls:ChannelMonitorControl
              x:Name="ChannelMonitorView"
              Height="24"
              Player="{Binding Player}" />

          <Canvas
                  x:Name="ChannelMixerPopupHost"
                  Height="24"
                  IsVisible="{Binding IsChannelMixerPopupOpen}"
                  ClipToBounds="False">
            <Grid
                Width="244"
                Height="206"
                Canvas.Left="{Binding ChannelMixerPopupLeft}"
                Canvas.Top="26"
                ZIndex="30">
              <Path
                  Data="{Binding ChannelMixerPopupOutlinePathData}"
                  Fill="{DynamicResource Theme.PopupBackgroundBrush}"
                  Stroke="{DynamicResource Theme.PopupBorderBrush}"
                  StrokeThickness="1" />

              <StackPanel
                  DataContext="{Binding SelectedChannelMixStrip}"
                  Margin="10,18,10,10"
                  Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Text="{Binding ChannelLabel}" FontSize="11" FontWeight="Bold" Classes="secondaryAccent" />
                  <TextBlock Grid.Column="1" Text="SEND" FontSize="9" FontWeight="Bold" Classes="accentMuted" />
                </Grid>

                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="VOL" FontSize="9" FontWeight="Bold" Classes="dim" VerticalAlignment="Center" />
                    <Slider
                        Grid.Column="2"
                        Minimum="0"
                        Maximum="200"
                        Value="{Binding VolumePercent, Mode=TwoWay}"
                        Foreground="{DynamicResource Theme.AccentBrush}"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset to 100%"
                        DoubleTapped="OnChannelVolumeSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding VolumeText}" FontSize="10" Classes="secondaryAccent" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="REV" FontSize="9" FontWeight="Bold" Classes="dim" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnChannelReverbModeClicked"
                        ToolTip.Tip="{Binding ReverbSendModeToolTip}">
                      <TextBlock Text="{Binding ReverbSendModeLabel}" FontSize="9" FontWeight="Bold" Classes="secondaryAccent" />
                    </Button>
                    <controls:KnobControl
                        Grid.Column="2"
                        Width="24" Height="24"
                        Minimum="{Binding ReverbSendMinimum}"
                        Maximum="{Binding ReverbSendMaximum}"
                        Value="{Binding ReverbSendValue, Mode=TwoWay}"
                        KnobBrush="{DynamicResource Theme.ButtonBackgroundBrush}"
                        IndicatorBrush="{DynamicResource Theme.AccentBrush}"
                        OutlineBrush="{DynamicResource Theme.ButtonBorderBrush}"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnChannelReverbSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding ReverbSendText}" FontSize="10" Classes="secondaryAccent" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="CHO" FontSize="9" FontWeight="Bold" Classes="dim" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnChannelChorusModeClicked"
                        ToolTip.Tip="{Binding ChorusSendModeToolTip}">
                      <TextBlock Text="{Binding ChorusSendModeLabel}" FontSize="9" FontWeight="Bold" Classes="secondaryAccent" />
                    </Button>
                    <controls:KnobControl
                        Grid.Column="2"
                        Width="24" Height="24"
                        Minimum="{Binding ChorusSendMinimum}"
                        Maximum="{Binding ChorusSendMaximum}"
                        Value="{Binding ChorusSendValue, Mode=TwoWay}"
                        KnobBrush="{DynamicResource Theme.ButtonBackgroundBrush}"
                        IndicatorBrush="{DynamicResource Theme.AccentBrush}"
                        OutlineBrush="{DynamicResource Theme.ButtonBorderBrush}"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnChannelChorusSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding ChorusSendText}" FontSize="10" Classes="secondaryAccent" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Grid>
          </Canvas>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Piano Roll / Visualizer -->
    <Border Grid.Row="2" Classes="panel" Margin="0,0,0,16" ClipToBounds="True">
      <Grid RowDefinitions="*,Auto">
        <Grid Margin="8" RowDefinitions="Auto,*" RowSpacing="8">
          <Grid>
            <Border Classes="pill" HorizontalAlignment="Center" Padding="4">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button
                    Classes="viewChip"
                    MinWidth="72"
                    Click="OnShowPianoRollViewClicked"
                    Background="{Binding PianoRollViewButtonBackground}"
                    BorderBrush="{Binding PianoRollViewButtonBorderBrush}"
                    Foreground="{Binding PianoRollViewButtonForeground}">
                  <TextBlock Text="ROLL" Foreground="{Binding PianoRollViewButtonForeground}" />
                </Button>
                <Button
                    Classes="viewChip"
                    MinWidth="72"
                    Click="OnShowMixViewClicked"
                    Background="{Binding MixViewButtonBackground}"
                    BorderBrush="{Binding MixViewButtonBorderBrush}"
                    Foreground="{Binding MixViewButtonForeground}">
                  <TextBlock Text="MIX" Foreground="{Binding MixViewButtonForeground}" />
                </Button>
                <Button
                    Classes="viewChip"
                    MinWidth="72"
                    Click="OnShowEffectsViewClicked"
                    Background="{Binding EffectsViewButtonBackground}"
                    BorderBrush="{Binding EffectsViewButtonBorderBrush}"
                    Foreground="{Binding EffectsViewButtonForeground}">
                  <TextBlock Text="FX" Foreground="{Binding EffectsViewButtonForeground}" />
                </Button>
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="1">
            <Border Classes="visualPanel" ClipToBounds="True">
              <Grid>
                <controls:PianoRollControl
                    IsVisible="{Binding IsPianoRollViewSelected}"
                    Player="{Binding Player}"
                    Notes="{Binding PianoRollNotes}"
                    TransposeOffsetSemitones="{Binding TransposeSemitones}" />

                <Grid IsVisible="{Binding IsMixViewSelected}" ColumnDefinitions="*,Auto">
                  <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ChannelMixRows}" Padding="12,12,24,12" VerticalAlignment="Stretch">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="6"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="panel" Padding="4,8" Width="52" VerticalAlignment="Stretch">
                            <Grid RowDefinitions="Auto,*,Auto">
                              <TextBlock Text="{Binding ChannelLabel}" FontSize="10" FontWeight="Bold" Classes="muted" HorizontalAlignment="Center" />
                              
                              <Grid Grid.Row="1" Margin="0,12">
                                 <Slider Orientation="Vertical" Minimum="0" Maximum="200" Value="{Binding VolumePercent, Mode=TwoWay}" Foreground="{DynamicResource Theme.AccentBrush}" HorizontalAlignment="Center" DoubleTapped="OnChannelVolumeSliderDoubleTapped" />
                                 <Border Classes="pill" VerticalAlignment="Bottom" HorizontalAlignment="Center" Padding="2,1" Margin="0,0,0,-8" IsHitTestVisible="False">
                                   <TextBlock Text="{Binding VolumeText}" FontSize="8" Classes="secondaryAccent" />
                                 </Border>
                              </Grid>

                              <StackPanel Grid.Row="2" Spacing="8">
                                <StackPanel Spacing="0">
                                  <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                                    <Button Grid.Column="0" Padding="0" Click="OnChannelReverbModeClicked" Background="Transparent" ToolTip.Tip="{Binding ReverbSendModeToolTip}">
                                      <TextBlock Text="{Binding ReverbSendModeLabel}" FontSize="8" FontWeight="Bold" Classes="accentMuted" VerticalAlignment="Center" />
                                    </Button>
                                    <TextBlock Grid.Column="1" Text="{Binding ReverbSendText}" FontSize="8" Classes="subtle" VerticalAlignment="Center" />
                                  </Grid>
                                  <controls:KnobControl Width="20" Height="20" Minimum="{Binding ReverbSendMinimum}" Maximum="{Binding ReverbSendMaximum}" Value="{Binding ReverbSendValue, Mode=TwoWay}" KnobBrush="{DynamicResource Theme.ButtonBackgroundBrush}" IndicatorBrush="{DynamicResource Theme.AccentBrush}" OutlineBrush="{DynamicResource Theme.ButtonBorderBrush}" Margin="4,0" DoubleTapped="OnChannelReverbSliderDoubleTapped" />
                                </StackPanel>

                                <StackPanel Spacing="0">
                                  <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                                    <Button Grid.Column="0" Padding="0" Click="OnChannelChorusModeClicked" Background="Transparent" ToolTip.Tip="{Binding ChorusSendModeToolTip}">
                                      <TextBlock Text="{Binding ChorusSendModeLabel}" FontSize="8" FontWeight="Bold" Classes="accentMuted" VerticalAlignment="Center" />
                                    </Button>
                                    <TextBlock Grid.Column="1" Text="{Binding ChorusSendText}" FontSize="8" Classes="subtle" VerticalAlignment="Center" />
                                  </Grid>
                                  <controls:KnobControl Width="20" Height="20" Minimum="{Binding ChorusSendMinimum}" Maximum="{Binding ChorusSendMaximum}" Value="{Binding ChorusSendValue, Mode=TwoWay}" KnobBrush="{DynamicResource Theme.ButtonBackgroundBrush}" IndicatorBrush="{DynamicResource Theme.AccentBrush}" OutlineBrush="{DynamicResource Theme.ButtonBorderBrush}" Margin="4,0" DoubleTapped="OnChannelChorusSliderDoubleTapped" />
                                </StackPanel>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <Border Grid.Column="1" Classes="panel" Padding="4,8" Width="60" Margin="0,12,12,12">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBlock Text="GLOBAL" FontSize="10" FontWeight="Bold" Classes="accent" HorizontalAlignment="Center" />
                      
                      <Grid Grid.Row="1" Margin="0,12">
                         <Slider Orientation="Vertical" Minimum="0" Maximum="200" Value="{Binding MasterVolumePercent, Mode=TwoWay}" Foreground="{DynamicResource Theme.AccentBrush}" HorizontalAlignment="Center" DoubleTapped="OnMasterVolumeSliderDoubleTapped" ToolTip.Tip="Double-click to reset to 100%" />
                         <Border Classes="pill" VerticalAlignment="Bottom" HorizontalAlignment="Center" Padding="2,1" Margin="0,0,0,-8" IsHitTestVisible="False">
                           <TextBlock Text="{Binding MasterVolumePercentText}" FontSize="8" Classes="secondaryAccent" />
                         </Border>
                      </Grid>

                      <StackPanel Grid.Row="2" Spacing="8">
                        <StackPanel Spacing="0">
                          <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                            <Button Grid.Column="0" Padding="0" Click="OnGlobalReverbModeClicked" Background="Transparent" ToolTip.Tip="{Binding GlobalReverbReturnModeToolTip}">
                              <TextBlock Text="{Binding GlobalReverbReturnModeLabel}" FontSize="8" FontWeight="Bold" Classes="accentMuted" VerticalAlignment="Center" />
                            </Button>
                            <TextBlock Grid.Column="1" Text="{Binding GlobalReverbReturnText}" FontSize="8" Classes="subtle" VerticalAlignment="Center" />
                          </Grid>
                          <controls:KnobControl Width="20" Height="20" Minimum="{Binding GlobalReverbReturnMinimum}" Maximum="{Binding GlobalReverbReturnMaximum}" Value="{Binding GlobalReverbReturnValue, Mode=TwoWay}" KnobBrush="{DynamicResource Theme.ButtonBackgroundBrush}" IndicatorBrush="{DynamicResource Theme.AccentBrush}" OutlineBrush="{DynamicResource Theme.ButtonBorderBrush}" Margin="4,0" DoubleTapped="OnReverbSliderDoubleTapped" ToolTip.Tip="Double-click to reset current mode" />
                        </StackPanel>

                        <StackPanel Spacing="0">
                          <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                            <Button Grid.Column="0" Padding="0" Click="OnGlobalChorusModeClicked" Background="Transparent" ToolTip.Tip="{Binding GlobalChorusReturnModeToolTip}">
                              <TextBlock Text="{Binding GlobalChorusReturnModeLabel}" FontSize="8" FontWeight="Bold" Classes="accentMuted" VerticalAlignment="Center" />
                            </Button>
                            <TextBlock Grid.Column="1" Text="{Binding GlobalChorusReturnText}" FontSize="8" Classes="subtle" VerticalAlignment="Center" />
                          </Grid>
                          <controls:KnobControl Width="20" Height="20" Minimum="{Binding GlobalChorusReturnMinimum}" Maximum="{Binding GlobalChorusReturnMaximum}" Value="{Binding GlobalChorusReturnValue, Mode=TwoWay}" KnobBrush="{DynamicResource Theme.ButtonBackgroundBrush}" IndicatorBrush="{DynamicResource Theme.AccentBrush}" OutlineBrush="{DynamicResource Theme.ButtonBorderBrush}" Margin="4,0" DoubleTapped="OnChorusSliderDoubleTapped" ToolTip.Tip="Double-click to reset current mode" />
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Grid>

                <Grid IsVisible="{Binding IsEffectsViewSelected}" Margin="12" RowDefinitions="Auto,*" RowSpacing="12">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="FX CHAIN" FontSize="12" FontWeight="Bold" Classes="accent" />
                      <TextBlock Text="{Binding EffectChainStatusText}" FontSize="12" Classes="muted" />
                      <TextBlock Text="Signal flows from top to bottom. Built-in FX and plug-ins are managed in the same chain." FontSize="11" Classes="hint" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Button
                          Classes="actionBtn"
                          Content="Add FX"
                          Click="OnLoadAudioPluginClicked"
                          IsEnabled="{Binding CanLoadAudioPlugin}"
                          Padding="14,8" />
                      <Button Classes="secondary" Content="Clear FX" Click="OnUnloadAudioPluginClicked" IsEnabled="{Binding CanUnloadAudioPlugin}" Padding="14,8" />
                    </StackPanel>
                  </Grid>

                  <ScrollViewer Grid.Row="1"
                                VerticalScrollBarVisibility="Visible"
                                HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding EffectChainItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:AudioEffectChainItem">
                          <Border Classes="panel" Margin="0,0,0,10" Padding="14">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                              <Border Classes="accentPill" Padding="10,4" VerticalAlignment="Top">
                                <TextBlock Text="{Binding FormatLabel}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.ToggleActiveForegroundBrush}" />
                              </Border>

                              <StackPanel Grid.Column="1" Spacing="4">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                  <TextBlock Text="{Binding DisplayName}"
                                             FontSize="15"
                                             FontWeight="SemiBold"
                                             Classes="secondaryAccent"
                                             TextTrimming="CharacterEllipsis" />
                                  <Border Grid.Column="1" Classes="pill" Padding="10,3">
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Classes="secondaryAccent" />
                                  </Border>
                                </Grid>

                                <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Classes="hint" />

                                <TextBlock Text="{Binding Path}"
                                           IsVisible="{Binding HasPath}"
                                           FontSize="11"
                                           Classes="hint"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding Path}" />
                              </StackPanel>

                              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button
                                    Classes="chainPrimaryBtn"
                                    MinWidth="58"
                                    Padding="10,6"
                                    Content="TOGGLE"
                                    Click="OnToggleEqFromEffectsViewClicked"
                                    IsVisible="{Binding IsEq}"
                                    ToolTip.Tip="Enable or bypass the built-in EQ." />
                                <Button
                                    Classes="chainPrimaryBtn"
                                    MinWidth="40"
                                    Padding="10,6"
                                    Content="UI"
                                    Click="OnOpenEffectChainItemEditorClicked"
                                    IsVisible="{Binding HasEditor}"
                                    ToolTip.Tip="Open the effect UI." />
                                <Button
                                    Classes="chainBtn"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    Content="↑"
                                    Click="OnMoveEffectChainItemUpClicked"
                                    IsEnabled="{Binding CanMoveUp}"
                                    ToolTip.Tip="Move earlier in the signal chain." />
                                <Button
                                    Classes="chainBtn"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    Content="↓"
                                    Click="OnMoveEffectChainItemDownClicked"
                                    IsEnabled="{Binding CanMoveDown}"
                                    ToolTip.Tip="Move later in the signal chain." />
                                <Button
                                    Classes="chainDangerBtn"
                                    MinWidth="64"
                                    Padding="10,6"
                                    Content="REMOVE"
                                    Click="OnRemoveEffectChainItemClicked"
                                    IsVisible="{Binding CanRemove}"
                                    ToolTip.Tip="Remove this plug-in from the chain." />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </Grid>
        
        <!-- Piano Keyboard -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="8,0,8,8">
          <Button
              Grid.Column="0"
              Classes="iconBtn"
              Width="44"
              Height="108"
              Padding="0"
              Click="OnTransposeDownClicked"
              IsEnabled="{Binding CanAdjustPlaybackModifiers}"
              ToolTip.Tip="Transpose down by one semitone">
            <StackPanel Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="KEY" FontSize="9" FontWeight="Bold" Classes="accentMuted" HorizontalAlignment="Center" />
              <TextBlock Text="−" FontSize="18" FontWeight="Bold" Classes="secondaryAccent" HorizontalAlignment="Center" />
            </StackPanel>
          </Button>

          <Grid Grid.Column="1" Height="108" RowDefinitions="Auto,Auto">
            <controls:PianoControl
                Grid.Row="0"
                Height="80"
                VerticalAlignment="Top"
                Player="{Binding Player}"
                TransposeOffsetSemitones="{Binding TransposeSemitones}" />

            <Border Grid.Row="1" Classes="pill" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,6,0,0" Padding="10,3">
              <TextBlock Text="{Binding TransposeSemitonesText}"
                         FontSize="10"
                         FontWeight="Bold"
                         Classes="secondaryAccent mono" />
            </Border>
          </Grid>

          <Button
              Grid.Column="2"
              Classes="iconBtn"
              Width="44"
              Height="108"
              Padding="0"
              Click="OnTransposeUpClicked"
              IsEnabled="{Binding CanAdjustPlaybackModifiers}"
              ToolTip.Tip="Transpose up by one semitone">
            <StackPanel Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="KEY" FontSize="9" FontWeight="Bold" Classes="accentMuted" HorizontalAlignment="Center" />
              <TextBlock Text="+" FontSize="18" FontWeight="Bold" Classes="secondaryAccent" HorizontalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>
      </Grid>
    </Border>

    <!-- Transport Controls -->
    <Border Grid.Row="3" Classes="panel" Padding="16">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="0,0,16,0" VerticalAlignment="Center">
          <Button Classes="transportBtn" Width="36" Height="36" Click="OnPlayPreviousClicked" ToolTip.Tip="Previous Track">
            <TextBlock Text="{Binding PreviousTrackButtonText}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
          <Button Classes="playPauseBtn" Width="48" Height="48" Click="OnPlayPauseClicked" IsEnabled="{Binding CanTogglePlayback}" Margin="4,0">
            <TextBlock Text="{Binding PlayPauseIcon}" FontSize="20" Foreground="{DynamicResource Theme.PlayPauseButtonForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{Binding PlayPauseIconMargin}"/>
          </Button>
          <Button Classes="transportBtn" Width="36" Height="36" Click="OnPlayNextClicked" ToolTip.Tip="Next Track">
            <TextBlock Text="{Binding NextTrackButtonText}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </StackPanel>
        
        <Grid Grid.Column="1" RowDefinitions="Auto,36" RowSpacing="4" VerticalAlignment="Center" ClipToBounds="False">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Text="{Binding PositionText}" FontSize="12" Classes="subtle mono" />
            <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="12" Classes="subtle mono" />
          </Grid>

          <StackPanel
              Grid.Row="1"
              Orientation="Horizontal"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,-24,0,0"
              Spacing="6"
              IsVisible="{Binding IsLoopBadgeVisible}"
              ZIndex="3">
            <Border
                Background="{Binding LoopBadgeBackground}"
                BorderBrush="{Binding LoopBadgeBorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Theme.PillCornerRadius}"
                MinHeight="22"
                Padding="10,0">
              <Grid Height="20">
                <TextBlock
                    Text="{Binding LoopRangeSummaryText}"
                    FontSize="10"
                    FontWeight="Bold"
                    Classes="mono"
                    Foreground="{Binding LoopBadgeForeground}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,1,0,0" />
              </Grid>
            </Border>

            <Button
                Classes="iconBtn"
                MinWidth="54"
                Height="22"
                Padding="8,0"
                Click="OnClearLoopRangeClicked"
                IsVisible="{Binding HasCustomLoopRange}"
                ToolTip.Tip="Remove the A-B range and return to full-track playback.">
              <Grid Height="20">
                <TextBlock
                    Text="CLEAR"
                    FontSize="10"
                    FontWeight="Bold"
                    Classes="secondaryAccent"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,1,0,0" />
              </Grid>
            </Button>
          </StackPanel>

          <controls:LoopTimelineControl
              Grid.Row="1"
              Height="36"
              Maximum="{Binding DurationSeconds}"
              Value="{Binding PositionSeconds}"
              LoopStart="{Binding LoopRangeStartSeconds}"
              LoopEnd="{Binding LoopRangeEndSeconds}"
              HasCustomLoopRange="{Binding HasCustomLoopRange}"
              IsLoopEnabled="{Binding IsLoopEnabled}"
              IsEnabled="{Binding CanSeek}"
              ToolTip.Tip="Drag to seek. Shift+Drag to create an A-B loop. Drag loop edges to resize."
              SeekStarted="OnTimelineSeekStarted"
              SeekChanged="OnTimelineSeekChanged"
              SeekCompleted="OnTimelineSeekCompleted"
              LoopRangeChanged="OnTimelineLoopRangeChanged"
              LoopRangeCleared="OnTimelineLoopRangeCleared" />
        </Grid>
        
        <StackPanel Grid.Column="2" Margin="16,0,0,0" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button
                Classes="iconBtn"
                Width="40"
                Height="40"
                Padding="0"
                CornerRadius="{DynamicResource Theme.RoundButtonCornerRadius}"
                Click="OnLoopClicked"
                ToolTip.Tip="{Binding LoopButtonToolTip}"
                Background="{Binding LoopButtonBackground}"
                BorderBrush="{Binding LoopButtonBorderBrush}">
              <Viewbox Width="18" Height="18" Stretch="Uniform">
                <Path Data="M 2 9 A 4 4 0 0 1 6 5 L 16 5 M 13 2 L 16 5 L 13 8 M 16 9 A 4 4 0 0 1 12 13 L 2 13 M 5 10 L 2 13 L 5 16"
                      Stroke="{Binding LoopButtonForeground}"
                      StrokeThickness="1.8"
                      StrokeLineCap="Round"
                      StrokeJoin="Round"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
              </Viewbox>
            </Button>

            <Grid x:Name="SpeedButtonHost" Width="74" Height="40" ClipToBounds="False">
              <Button
                  Width="74"
                  Height="40"
                  Padding="12,6"
                  Click="OnSpeedButtonClicked"
                  IsEnabled="{Binding CanAdjustPlaybackModifiers}"
                  Background="{Binding SpeedButtonBackground}"
                  BorderBrush="{Binding SpeedButtonBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource Theme.PillCornerRadius}">
                <StackPanel Spacing="1">
                  <TextBlock Text="BPM"
                             FontSize="10"
                             FontWeight="Bold"
                             Foreground="{Binding SpeedButtonForeground}"
                             HorizontalAlignment="Right" />
                  <TextBlock Text="{Binding CurrentBpmText}"
                             FontSize="14"
                             Foreground="{Binding SpeedButtonForeground}"
                             HorizontalAlignment="Right"
                             Classes="mono" />
                </StackPanel>
              </Button>

              <Border IsVisible="{Binding IsSpeedPopupOpen}" Classes="popupPanel" ZIndex="20" Width="240" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-102,0,0" Padding="10">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="TEMPO OVERRIDE" FontSize="10" FontWeight="Bold" Classes="secondaryAccent" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding PlaybackSpeedPercentText}"
                               FontSize="10"
                               FontWeight="Bold"
                               Classes="secondaryAccent mono" />
                  </Grid>

                  <Slider
                      Minimum="25"
                      Maximum="400"
                      Value="{Binding PlaybackSpeedPercent, Mode=TwoWay}"
                      IsEnabled="{Binding CanAdjustPlaybackModifiers}"
                      Foreground="{DynamicResource Theme.AccentBrush}"
                      SmallChange="1"
                      LargeChange="10"
                      ToolTip.Tip="Override playback speed. Double-click to reset to 100%."
                      DoubleTapped="OnPlaybackSpeedSliderDoubleTapped" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
    </Grid>

    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Classes="playlistToggleBtn"
            Click="OnTogglePlaylistClicked"
            Margin="{Binding PlaylistToggleMargin}"
            ZIndex="51"
            ToolTip.Tip="Toggle Playlist">
      <TextBlock Text="{Binding PlaylistToggleIcon}" FontSize="10"/>
    </Button>

    <Border HorizontalAlignment="Right" VerticalAlignment="Stretch" Classes="sidebar" IsVisible="{Binding IsPlaylistVisible}" Width="300" ZIndex="50">
      <Grid RowDefinitions="Auto,*">
        <Border BorderBrush="{DynamicResource Theme.SidebarBorderBrush}" BorderThickness="0,0,0,1" Padding="12">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBlock Text="PLAYLIST" FontWeight="Bold" FontSize="14" Classes="accent" VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="iconBtn" Click="OnToggleSortClicked" Padding="8,4" Margin="0">
              <TextBlock x:Name="SortIconText" Text="↓ A-Z" FontSize="11" FontWeight="Bold" Classes="muted" />
            </Button>
          </Grid>
        </Border>

        <ListBox Grid.Row="1" ItemsSource="{Binding Playlist}" Background="Transparent" SelectionChanged="OnPlaylistSelectionChanged">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="12,8" />
              <Setter Property="Cursor" Value="Hand" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:PlaylistItem">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Background="Transparent">
                <TextBlock Grid.Column="0" Text="▶" Classes="accent" IsVisible="{Binding IsPlaying}" VerticalAlignment="Center" Width="14" FontSize="10" />
                <TextBlock Grid.Column="0" Text="" IsVisible="{Binding !IsPlaying}" Width="14" />
                
                <TextBlock Grid.Column="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="13" />
                
                <TextBlock Grid.Column="2" Text="{Binding DurationText}" Classes="subtle mono" FontSize="12" VerticalAlignment="Center" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Panel>
</Window>
