<Window
    x:Class="MidiPlayer.App.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:MidiPlayer.App.Controls"
    xmlns:models="using:MidiPlayer.App.Models"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
    Title="Kintsugi Midi Player"
    Width="820"
    Height="560"
    MinWidth="700"
    MinHeight="460"
    WindowStartupLocation="CenterScreen"
    Background="#101010">
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#E0E0E0" />
    </Style>
    <Style Selector="ToolTip">
      <Setter Property="Background" Value="#0D0D0D" />
      <Setter Property="BorderBrush" Value="#303030" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#DCEEFF" />
    </Style>
    <Style Selector="ToolTip TextBlock">
      <Setter Property="Foreground" Value="#DCEEFF" />
    </Style>
    <Style Selector="Button.iconBtn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#333" />
      <Setter Property="Foreground" Value="#C8D7E6" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
    </Style>
    <Style Selector="Button.iconBtn:disabled">
      <Setter Property="Foreground" Value="#8091A2" />
    </Style>
    <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#303030" />
    </Style>
    <Style Selector="Button.actionBtn">
      <Setter Property="Background" Value="#163553" />
      <Setter Property="BorderBrush" Value="#3A74B0" />
      <Setter Property="Foreground" Value="#DCEEFF" />
    </Style>
    <Style Selector="Button.actionBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#214B75" />
    </Style>
    <Style Selector="Button.chainBtn">
      <Setter Property="Background" Value="#1C1C1C" />
      <Setter Property="BorderBrush" Value="#333333" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E0E0E0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Focusable" Value="False" />
    </Style>
    <Style Selector="Button.chainBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#263241" />
    </Style>
    <Style Selector="Button.chainBtn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#314254" />
    </Style>
    <Style Selector="Button.chainPrimaryBtn">
      <Setter Property="Background" Value="#202A36" />
      <Setter Property="BorderBrush" Value="#3A74B0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#DCEEFF" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Focusable" Value="False" />
    </Style>
    <Style Selector="Button.chainPrimaryBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#274364" />
    </Style>
    <Style Selector="Button.chainPrimaryBtn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#32567E" />
    </Style>
    <Style Selector="Button.chainDangerBtn">
      <Setter Property="Background" Value="#261516" />
      <Setter Property="BorderBrush" Value="#7A3B42" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#F1D1D3" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Focusable" Value="False" />
    </Style>
    <Style Selector="Button.chainDangerBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#3A1C1E" />
    </Style>
    <Style Selector="Button.chainDangerBtn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#4B2428" />
    </Style>
    <Style Selector="Button.viewChip">
      <Setter Property="Background" Value="#171717" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#2F2F2F" />
      <Setter Property="Foreground" Value="#A0A0A0" />
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Focusable" Value="False" />
    </Style>
    <Style Selector="Button.viewChip:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#202A36" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Focusable" Value="False" />
    </Style>
  </Window.Styles>

  <Panel>
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalAlignment="Center" ClipToBounds="True" Margin="0,0,12,0">
        <TextBlock Text="KINTSUGI MIDI PLAYER" FontSize="16" FontWeight="Bold" Foreground="#4A90E2" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding MidiDisplayName}"
                   FontSize="14"
                   FontWeight="Normal"
                   Foreground="#A0A0A0"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <Border Grid.Column="2"
                Background="#171717"
                BorderBrush="#2F2F2F"
                BorderThickness="1"
                CornerRadius="999"
                Padding="8,3"
                VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText}"
                     FontSize="11"
                     Foreground="#888"
                     VerticalAlignment="Center"
                     MaxWidth="180"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding StatusText}" />
        </Border>
      </Grid>
        <Button Grid.Column="1" Classes="iconBtn" FontSize="11" FontWeight="Bold" Margin="0,0,8,0">
          <TextBlock Text="ACTIONS ▾" Foreground="#C8D7E6" />
          <Button.Flyout>
            <MenuFlyout>
              <MenuItem Header="Open File..." Click="OnOpenMidiClicked" IsEnabled="{Binding CanOpenMidi}" />
              <MenuItem Header="Export Audio..." Click="OnExportWavClicked" IsEnabled="{Binding CanExport}" />
              <MenuItem Header="Browse Events..." Click="OnBrowseMidiEventsClicked" IsEnabled="{Binding CanBrowseMidiEvents}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
        <Button Grid.Column="2" Classes="iconBtn" Click="OnSettingsClicked" ToolTip.Tip="Settings" IsEnabled="{Binding CanOpenSettings}">
          <TextBlock Text="⚙" FontSize="14" />
        </Button>
      </Grid>

    <!-- Channel Monitor -->
    <Border Grid.Row="1"
            Background="#181818"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8"
            Margin="0,0,0,16"
            ClipToBounds="False"
            ZIndex="20">
      <StackPanel Spacing="8">
        <TextBlock Text="CHANNEL ACTIVITY" FontSize="10" FontWeight="Bold" Foreground="#666" />
        <Grid Height="24" ClipToBounds="False">
          <controls:ChannelMonitorControl
              x:Name="ChannelMonitorView"
              Height="24"
              Player="{Binding Player}" />

          <Canvas
                  x:Name="ChannelMixerPopupHost"
                  Height="24"
                  IsVisible="{Binding IsChannelMixerPopupOpen}"
                  ClipToBounds="False">
            <Grid
                Width="244"
                Height="206"
                Canvas.Left="{Binding ChannelMixerPopupLeft}"
                Canvas.Top="26"
                ZIndex="30">
              <Path
                  Data="{Binding ChannelMixerPopupOutlinePathData}"
                  Fill="#111111"
                  Stroke="#3A74B0"
                  StrokeThickness="1" />

              <StackPanel
                  DataContext="{Binding SelectedChannelMixStrip}"
                  Margin="10,18,10,10"
                  Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Text="{Binding ChannelLabel}" FontSize="11" FontWeight="Bold" Foreground="#DCEEFF" />
                  <TextBlock Grid.Column="1" Text="SEND" FontSize="9" FontWeight="Bold" Foreground="#5D88B4" />
                </Grid>

                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="VOL" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Slider
                        Grid.Column="2"
                        Minimum="0"
                        Maximum="200"
                        Value="{Binding VolumePercent, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset to 100%"
                        DoubleTapped="OnChannelVolumeSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding VolumeText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="REV" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnChannelReverbModeClicked"
                        ToolTip.Tip="{Binding ReverbSendModeToolTip}">
                      <TextBlock Text="{Binding ReverbSendModeLabel}" FontSize="9" FontWeight="Bold" Foreground="#B6D6F8" />
                    </Button>
                    <Slider
                        Grid.Column="2"
                        Minimum="{Binding ReverbSendMinimum}"
                        Maximum="{Binding ReverbSendMaximum}"
                        Value="{Binding ReverbSendValue, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnChannelReverbSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding ReverbSendText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <TextBlock Text="CHO" FontSize="9" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        MinWidth="34"
                        Height="20"
                        Padding="6,0"
                        Click="OnChannelChorusModeClicked"
                        ToolTip.Tip="{Binding ChorusSendModeToolTip}">
                      <TextBlock Text="{Binding ChorusSendModeLabel}" FontSize="9" FontWeight="Bold" Foreground="#B6D6F8" />
                    </Button>
                    <Slider
                        Grid.Column="2"
                        Minimum="{Binding ChorusSendMinimum}"
                        Maximum="{Binding ChorusSendMaximum}"
                        Value="{Binding ChorusSendValue, Mode=TwoWay}"
                        Foreground="#4A90E2"
                        SmallChange="1"
                        LargeChange="10"
                        ToolTip.Tip="Double-click to reset current mode"
                        DoubleTapped="OnChannelChorusSliderDoubleTapped" />
                    <TextBlock Grid.Column="3" Text="{Binding ChorusSendText}" FontSize="10" Foreground="#B6D6F8" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Grid>
          </Canvas>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Piano Roll / Visualizer -->
    <Border Grid.Row="2" Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16" ClipToBounds="True">
      <Grid RowDefinitions="*,Auto">
        <Grid Margin="8" RowDefinitions="Auto,*" RowSpacing="8">
          <Grid ColumnDefinitions="44,*,44" ColumnSpacing="8">
            <Border
                Grid.Column="1"
                HorizontalAlignment="Center"
                Background="#111111CC"
                BorderBrush="#2F2F2F"
                BorderThickness="1"
                CornerRadius="999"
                Padding="4">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button
                    Classes="viewChip"
                    MinWidth="72"
                    Click="OnShowEqViewClicked"
                    Background="{Binding EqViewButtonBackground}"
                    BorderBrush="{Binding EqViewButtonBorderBrush}"
                    Foreground="{Binding EqViewButtonForeground}">
                  <TextBlock Text="EQ" Foreground="{Binding EqViewButtonForeground}" />
                </Button>
                <Button
                    Classes="viewChip"
                    MinWidth="72"
                    Click="OnShowPianoRollViewClicked"
                    Background="{Binding PianoRollViewButtonBackground}"
                    BorderBrush="{Binding PianoRollViewButtonBorderBrush}"
                    Foreground="{Binding PianoRollViewButtonForeground}">
                  <TextBlock Text="ROLL" Foreground="{Binding PianoRollViewButtonForeground}" />
                </Button>
                <Button
                    Classes="viewChip"
                    MinWidth="72"
                    Click="OnShowMixViewClicked"
                    Background="{Binding MixViewButtonBackground}"
                    BorderBrush="{Binding MixViewButtonBorderBrush}"
                    Foreground="{Binding MixViewButtonForeground}">
                  <TextBlock Text="MIX" Foreground="{Binding MixViewButtonForeground}" />
                </Button>
                <Button
                    Classes="viewChip"
                    MinWidth="72"
                    Click="OnShowEffectsViewClicked"
                    Background="{Binding EffectsViewButtonBackground}"
                    BorderBrush="{Binding EffectsViewButtonBorderBrush}"
                    Foreground="{Binding EffectsViewButtonForeground}">
                  <TextBlock Text="FX" Foreground="{Binding EffectsViewButtonForeground}" />
                </Button>
              </StackPanel>
            </Border>

            <Button
                Grid.Column="2"
                Width="36"
                Height="36"
                Padding="0"
                Click="OnEqToggleClicked"
                IsVisible="{Binding IsEqViewSelected}"
                Background="{Binding EqButtonBackground}"
                BorderBrush="{Binding EqButtonBorderBrush}"
                Foreground="{Binding EqButtonForeground}"
                CornerRadius="18"
                ToolTip.Tip="{Binding EqButtonToolTip}">
              <Grid Width="18" Height="18">
                <Path
                    Data="M 9 2 L 9 8"
                    Stroke="{Binding EqButtonForeground}"
                    StrokeThickness="2.2"
                    StrokeLineCap="Round" />
                <Path
                    Data="M 4.5 5 A 6.5 6.5 0 1 0 13.5 5"
                    Stroke="{Binding EqButtonForeground}"
                    StrokeThickness="2.2"
                    StrokeLineCap="Round" />
              </Grid>
            </Button>
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="44,*,44" ColumnSpacing="8">
            <Border
                Grid.Column="1"
                Background="#0C1119"
                BorderBrush="#1E2A38"
                BorderThickness="1"
                CornerRadius="4"
                ClipToBounds="True">
              <Grid>
                <controls:SpectrumControl
                    IsVisible="{Binding IsEqViewSelected}"
                    Player="{Binding Player}"
                    IsEqEnabled="{Binding IsEqEnabled}" />

                <controls:PianoRollControl
                    IsVisible="{Binding IsPianoRollViewSelected}"
                    Player="{Binding Player}"
                    Notes="{Binding PianoRollNotes}"
                    TransposeOffsetSemitones="{Binding TransposeSemitones}" />

                <Grid IsVisible="{Binding IsMixViewSelected}" ColumnDefinitions="*,Auto">
                  <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ChannelMixRows}" Padding="12,12,24,12">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="6"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="4" Padding="4,8" Width="52">
                            <Grid RowDefinitions="Auto,*,Auto">
                              <TextBlock Text="{Binding ChannelLabel}" FontSize="10" FontWeight="Bold" Foreground="#A0A0A0" HorizontalAlignment="Center" />
                              
                              <Grid Grid.Row="1" Margin="0,12">
                                 <Slider Orientation="Vertical" Minimum="0" Maximum="200" Value="{Binding VolumePercent, Mode=TwoWay}" Foreground="#4A90E2" HorizontalAlignment="Center" DoubleTapped="OnChannelVolumeSliderDoubleTapped" />
                                 <Border Background="#111111CC" CornerRadius="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Padding="2,1" Margin="0,0,0,-8" IsHitTestVisible="False">
                                   <TextBlock Text="{Binding VolumeText}" FontSize="8" Foreground="#DCEEFF" />
                                 </Border>
                              </Grid>

                              <StackPanel Grid.Row="2" Spacing="8">
                                <StackPanel Spacing="0">
                                  <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                                    <Button Grid.Column="0" Padding="0" Click="OnChannelReverbModeClicked" Background="Transparent" ToolTip.Tip="{Binding ReverbSendModeToolTip}">
                                      <TextBlock Text="{Binding ReverbSendModeLabel}" FontSize="8" FontWeight="Bold" Foreground="#5D88B4" VerticalAlignment="Center" />
                                    </Button>
                                    <TextBlock Grid.Column="1" Text="{Binding ReverbSendText}" FontSize="8" Foreground="#888" VerticalAlignment="Center" />
                                  </Grid>
                                  <Slider Minimum="{Binding ReverbSendMinimum}" Maximum="{Binding ReverbSendMaximum}" Value="{Binding ReverbSendValue, Mode=TwoWay}" Foreground="#214B75" Margin="4,0" DoubleTapped="OnChannelReverbSliderDoubleTapped" />
                                </StackPanel>

                                <StackPanel Spacing="0">
                                  <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                                    <Button Grid.Column="0" Padding="0" Click="OnChannelChorusModeClicked" Background="Transparent" ToolTip.Tip="{Binding ChorusSendModeToolTip}">
                                      <TextBlock Text="{Binding ChorusSendModeLabel}" FontSize="8" FontWeight="Bold" Foreground="#5D88B4" VerticalAlignment="Center" />
                                    </Button>
                                    <TextBlock Grid.Column="1" Text="{Binding ChorusSendText}" FontSize="8" Foreground="#888" VerticalAlignment="Center" />
                                  </Grid>
                                  <Slider Minimum="{Binding ChorusSendMinimum}" Maximum="{Binding ChorusSendMaximum}" Value="{Binding ChorusSendValue, Mode=TwoWay}" Foreground="#214B75" Margin="4,0" DoubleTapped="OnChannelChorusSliderDoubleTapped" />
                                </StackPanel>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <Border Grid.Column="1" Background="#111" BorderBrush="#3A74B0" BorderThickness="1" CornerRadius="4" Padding="4,8" Width="60" Margin="0,12,12,12">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBlock Text="GLOBAL" FontSize="10" FontWeight="Bold" Foreground="#4A90E2" HorizontalAlignment="Center" />
                      
                      <Grid Grid.Row="1" Margin="0,12">
                         <Slider Orientation="Vertical" Minimum="0" Maximum="200" Value="{Binding MasterVolumePercent, Mode=TwoWay}" Foreground="#4A90E2" HorizontalAlignment="Center" DoubleTapped="OnMasterVolumeSliderDoubleTapped" ToolTip.Tip="Double-click to reset to 100%" />
                         <Border Background="#111111CC" CornerRadius="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Padding="2,1" Margin="0,0,0,-8" IsHitTestVisible="False">
                           <TextBlock Text="{Binding MasterVolumePercentText}" FontSize="8" Foreground="#DCEEFF" />
                         </Border>
                      </Grid>

                      <StackPanel Grid.Row="2" Spacing="8">
                        <StackPanel Spacing="0">
                          <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                            <Button Grid.Column="0" Padding="0" Click="OnGlobalReverbModeClicked" Background="Transparent" ToolTip.Tip="{Binding GlobalReverbReturnModeToolTip}">
                              <TextBlock Text="{Binding GlobalReverbReturnModeLabel}" FontSize="8" FontWeight="Bold" Foreground="#5D88B4" VerticalAlignment="Center" />
                            </Button>
                            <TextBlock Grid.Column="1" Text="{Binding GlobalReverbReturnText}" FontSize="8" Foreground="#888" VerticalAlignment="Center" />
                          </Grid>
                          <Slider Minimum="{Binding GlobalReverbReturnMinimum}" Maximum="{Binding GlobalReverbReturnMaximum}" Value="{Binding GlobalReverbReturnValue, Mode=TwoWay}" Foreground="#214B75" Margin="4,0" DoubleTapped="OnReverbSliderDoubleTapped" ToolTip.Tip="Double-click to reset current mode" />
                        </StackPanel>

                        <StackPanel Spacing="0">
                          <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                            <Button Grid.Column="0" Padding="0" Click="OnGlobalChorusModeClicked" Background="Transparent" ToolTip.Tip="{Binding GlobalChorusReturnModeToolTip}">
                              <TextBlock Text="{Binding GlobalChorusReturnModeLabel}" FontSize="8" FontWeight="Bold" Foreground="#5D88B4" VerticalAlignment="Center" />
                            </Button>
                            <TextBlock Grid.Column="1" Text="{Binding GlobalChorusReturnText}" FontSize="8" Foreground="#888" VerticalAlignment="Center" />
                          </Grid>
                          <Slider Minimum="{Binding GlobalChorusReturnMinimum}" Maximum="{Binding GlobalChorusReturnMaximum}" Value="{Binding GlobalChorusReturnValue, Mode=TwoWay}" Foreground="#214B75" Margin="4,0" DoubleTapped="OnChorusSliderDoubleTapped" ToolTip.Tip="Double-click to reset current mode" />
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Grid>

                <Grid IsVisible="{Binding IsEffectsViewSelected}" Margin="12" RowDefinitions="Auto,*" RowSpacing="12">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="FX CHAIN" FontSize="12" FontWeight="Bold" Foreground="#4A90E2" />
                      <TextBlock Text="{Binding EffectChainStatusText}" FontSize="12" Foreground="#A0A0A0" />
                      <TextBlock Text="Signal flows from top to bottom. EQ can be moved like any plug-in." FontSize="11" Foreground="#6D7C8C" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Button
                          Classes="actionBtn"
                          Content="Add FX"
                          Click="OnLoadAudioPluginClicked"
                          IsEnabled="{Binding CanLoadAudioPlugin}"
                          Padding="14,8" />
                      <Button
                          Background="#1C1C1C"
                          Foreground="#E0E0E0"
                          BorderBrush="#333333"
                          BorderThickness="1"
                          Content="Clear FX"
                          Click="OnUnloadAudioPluginClicked"
                          IsEnabled="{Binding CanUnloadAudioPlugin}"
                          Padding="14,8" />
                    </StackPanel>
                  </Grid>

                  <ScrollViewer Grid.Row="1"
                                VerticalScrollBarVisibility="Visible"
                                HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding EffectChainItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:AudioEffectChainItem">
                          <Border Margin="0,0,0,10"
                                  Padding="14"
                                  Background="#111111"
                                  BorderBrush="#263241"
                                  BorderThickness="1"
                                  CornerRadius="8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                              <Border Background="#13283E"
                                      BorderBrush="#3A74B0"
                                      BorderThickness="1"
                                      CornerRadius="999"
                                      Padding="10,4"
                                      VerticalAlignment="Top">
                                <TextBlock Text="{Binding FormatLabel}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#DCEEFF" />
                              </Border>

                              <StackPanel Grid.Column="1" Spacing="4">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                  <TextBlock Text="{Binding DisplayName}"
                                             FontSize="15"
                                             FontWeight="SemiBold"
                                             Foreground="#DCEEFF"
                                             TextTrimming="CharacterEllipsis" />
                                  <Border Grid.Column="1"
                                          Background="#171F29"
                                          BorderBrush="#314254"
                                          BorderThickness="1"
                                          CornerRadius="999"
                                          Padding="10,3">
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="#B6D6F8" />
                                  </Border>
                                </Grid>

                                <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Foreground="#8BA1B7" />

                                <TextBlock Text="{Binding Path}"
                                           IsVisible="{Binding HasPath}"
                                           FontSize="11"
                                           Foreground="#6D7C8C"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding Path}" />
                              </StackPanel>

                              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button
                                    Classes="chainPrimaryBtn"
                                    MinWidth="58"
                                    Padding="10,6"
                                    Content="TOGGLE"
                                    Click="OnToggleEqFromEffectsViewClicked"
                                    IsVisible="{Binding IsEq}"
                                    ToolTip.Tip="Enable or bypass the built-in EQ." />
                                <Button
                                    Classes="chainPrimaryBtn"
                                    MinWidth="40"
                                    Padding="10,6"
                                    Content="UI"
                                    Tag="{Binding ItemId}"
                                    Click="OnOpenEffectChainItemEditorClicked"
                                    IsVisible="{Binding HasEditor}"
                                    ToolTip.Tip="Open the plug-in editor." />
                                <Button
                                    Classes="chainBtn"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    Content="↑"
                                    Tag="{Binding ItemId}"
                                    Click="OnMoveEffectChainItemUpClicked"
                                    IsEnabled="{Binding CanMoveUp}"
                                    ToolTip.Tip="Move earlier in the signal chain." />
                                <Button
                                    Classes="chainBtn"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    Content="↓"
                                    Tag="{Binding ItemId}"
                                    Click="OnMoveEffectChainItemDownClicked"
                                    IsEnabled="{Binding CanMoveDown}"
                                    ToolTip.Tip="Move later in the signal chain." />
                                <Button
                                    Classes="chainDangerBtn"
                                    MinWidth="64"
                                    Padding="10,6"
                                    Content="REMOVE"
                                    Tag="{Binding ItemId}"
                                    Click="OnRemoveEffectChainItemClicked"
                                    IsVisible="{Binding CanRemove}"
                                    ToolTip.Tip="Remove this plug-in from the chain." />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </Grid>
        
        <!-- Piano Keyboard -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="8,0,8,8">
          <Button
              Grid.Column="0"
              Classes="iconBtn"
              Width="44"
              Height="108"
              Padding="0"
              Click="OnTransposeDownClicked"
              IsEnabled="{Binding CanAdjustPlaybackModifiers}"
              ToolTip.Tip="Transpose down by one semitone">
            <StackPanel Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="KEY" FontSize="9" FontWeight="Bold" Foreground="#6A8FB4" HorizontalAlignment="Center" />
              <TextBlock Text="−" FontSize="18" FontWeight="Bold" Foreground="#DCEEFF" HorizontalAlignment="Center" />
            </StackPanel>
          </Button>

          <Grid Grid.Column="1" Height="108" RowDefinitions="Auto,Auto">
            <controls:PianoControl
                Grid.Row="0"
                Height="80"
                VerticalAlignment="Top"
                Player="{Binding Player}"
                TransposeOffsetSemitones="{Binding TransposeSemitones}" />

            <Border
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,6,0,0"
                Background="#111111CC"
                BorderBrush="#2F2F2F"
                BorderThickness="1"
                CornerRadius="999"
                Padding="10,3">
              <TextBlock Text="{Binding TransposeSemitonesText}"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="#B6D6F8"
                         FontFamily="Courier New" />
            </Border>
          </Grid>

          <Button
              Grid.Column="2"
              Classes="iconBtn"
              Width="44"
              Height="108"
              Padding="0"
              Click="OnTransposeUpClicked"
              IsEnabled="{Binding CanAdjustPlaybackModifiers}"
              ToolTip.Tip="Transpose up by one semitone">
            <StackPanel Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="KEY" FontSize="9" FontWeight="Bold" Foreground="#6A8FB4" HorizontalAlignment="Center" />
              <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="#DCEEFF" HorizontalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>
      </Grid>
    </Border>

    <!-- Transport Controls -->
    <Border Grid.Row="3" Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Padding="16">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="0,0,16,0" VerticalAlignment="Center">
          <Button Classes="iconBtn" Width="36" Height="36" CornerRadius="18" Padding="0" Click="OnPlayPreviousClicked" ToolTip.Tip="Previous Track">
            <TextBlock Text="⏮" FontSize="16" Foreground="#C8D7E6" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
          <Button Width="48" Height="48" CornerRadius="24" Background="#4A90E2" BorderThickness="0" Click="OnPlayPauseClicked" IsEnabled="{Binding CanTogglePlayback}" Margin="4,0">
            <TextBlock Text="{Binding PlayPauseIcon}" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{Binding PlayPauseIconMargin}"/>
          </Button>
          <Button Classes="iconBtn" Width="36" Height="36" CornerRadius="18" Padding="0" Click="OnPlayNextClicked" ToolTip.Tip="Next Track">
            <TextBlock Text="⏭" FontSize="16" Foreground="#C8D7E6" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </StackPanel>
        
        <Grid Grid.Column="1" RowDefinitions="Auto,36" RowSpacing="4" VerticalAlignment="Center" ClipToBounds="False">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Text="{Binding PositionText}" FontSize="12" Foreground="#888" FontFamily="Courier New" />
            <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="12" Foreground="#888" FontFamily="Courier New" />
          </Grid>

          <StackPanel
              Grid.Row="1"
              Orientation="Horizontal"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,-24,0,0"
              Spacing="6"
              IsVisible="{Binding IsLoopBadgeVisible}"
              ZIndex="3">
            <Border
                Background="{Binding LoopBadgeBackground}"
                BorderBrush="{Binding LoopBadgeBorderBrush}"
                BorderThickness="1"
                CornerRadius="999"
                MinHeight="22"
                Padding="10,0">
              <Grid Height="20">
                <TextBlock
                    Text="{Binding LoopRangeSummaryText}"
                    FontSize="10"
                    FontWeight="Bold"
                    FontFamily="Courier New"
                    Foreground="{Binding LoopBadgeForeground}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,1,0,0" />
              </Grid>
            </Border>

            <Button
                Classes="iconBtn"
                MinWidth="54"
                Height="22"
                Padding="8,0"
                Click="OnClearLoopRangeClicked"
                IsVisible="{Binding HasCustomLoopRange}"
                ToolTip.Tip="Remove the A-B range and return to full-track playback.">
              <Grid Height="20">
                <TextBlock
                    Text="CLEAR"
                    FontSize="10"
                    FontWeight="Bold"
                    Foreground="#B6D6F8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,1,0,0" />
              </Grid>
            </Button>
          </StackPanel>

          <controls:LoopTimelineControl
              Grid.Row="1"
              Height="36"
              Maximum="{Binding DurationSeconds}"
              Value="{Binding PositionSeconds}"
              LoopStart="{Binding LoopRangeStartSeconds}"
              LoopEnd="{Binding LoopRangeEndSeconds}"
              HasCustomLoopRange="{Binding HasCustomLoopRange}"
              IsLoopEnabled="{Binding IsLoopEnabled}"
              IsEnabled="{Binding CanSeek}"
              ToolTip.Tip="Drag to seek. Shift+Drag to create an A-B loop. Drag loop edges to resize."
              SeekStarted="OnTimelineSeekStarted"
              SeekChanged="OnTimelineSeekChanged"
              SeekCompleted="OnTimelineSeekCompleted"
              LoopRangeChanged="OnTimelineLoopRangeChanged"
              LoopRangeCleared="OnTimelineLoopRangeCleared" />
        </Grid>
        
        <StackPanel Grid.Column="2" Margin="16,0,0,0" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button
                Classes="iconBtn"
                Width="40"
                Height="40"
                Padding="0"
                CornerRadius="20"
                Click="OnLoopClicked"
                ToolTip.Tip="{Binding LoopButtonToolTip}"
                Background="{Binding LoopButtonBackground}"
                BorderBrush="{Binding LoopButtonBorderBrush}">
              <Viewbox Width="18" Height="18" Stretch="Uniform">
                <Path Data="M 2 9 A 4 4 0 0 1 6 5 L 16 5 M 13 2 L 16 5 L 13 8 M 16 9 A 4 4 0 0 1 12 13 L 2 13 M 5 10 L 2 13 L 5 16"
                      Stroke="{Binding LoopButtonForeground}"
                      StrokeThickness="1.8"
                      StrokeLineCap="Round"
                      StrokeJoin="Round"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
              </Viewbox>
            </Button>

            <Grid x:Name="SpeedButtonHost" Width="74" Height="40" ClipToBounds="False">
              <Button
                  Width="74"
                  Height="40"
                  Padding="12,6"
                  Click="OnSpeedButtonClicked"
                  IsEnabled="{Binding CanAdjustPlaybackModifiers}"
                  Background="{Binding SpeedButtonBackground}"
                  BorderBrush="{Binding SpeedButtonBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="999">
                <StackPanel Spacing="1">
                  <TextBlock Text="BPM"
                             FontSize="10"
                             FontWeight="Bold"
                             Foreground="{Binding SpeedButtonForeground}"
                             HorizontalAlignment="Right" />
                  <TextBlock Text="{Binding CurrentBpmText}"
                             FontSize="14"
                             Foreground="{Binding SpeedButtonForeground}"
                             HorizontalAlignment="Right"
                             FontFamily="Courier New" />
                </StackPanel>
              </Button>

              <Border
                  IsVisible="{Binding IsSpeedPopupOpen}"
                  ZIndex="20"
                  Width="240"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,-102,0,0"
                  Background="#111111"
                  BorderBrush="#3A74B0"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="TEMPO OVERRIDE" FontSize="10" FontWeight="Bold" Foreground="#DCEEFF" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding PlaybackSpeedPercentText}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#B6D6F8"
                               FontFamily="Courier New" />
                  </Grid>

                  <Slider
                      Minimum="25"
                      Maximum="400"
                      Value="{Binding PlaybackSpeedPercent, Mode=TwoWay}"
                      IsEnabled="{Binding CanAdjustPlaybackModifiers}"
                      Foreground="#4A90E2"
                      SmallChange="1"
                      LargeChange="10"
                      ToolTip.Tip="Override playback speed. Double-click to reset to 100%."
                      DoubleTapped="OnPlaybackSpeedSliderDoubleTapped" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
    </Grid>

    <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
            Background="#1A1A1A" BorderBrush="#333" BorderThickness="1,1,0,1" CornerRadius="8,0,0,8"
            Click="OnTogglePlaylistClicked"
            Margin="{Binding PlaylistToggleMargin}"
            ZIndex="51"
            Padding="4,24"
            ToolTip.Tip="Toggle Playlist">
      <TextBlock Text="{Binding PlaylistToggleIcon}" Foreground="#888" FontSize="10"/>
    </Button>

    <Border HorizontalAlignment="Right" VerticalAlignment="Stretch"
            IsVisible="{Binding IsPlaylistVisible}"
            Width="300"
            Background="#121212" 
            BorderBrush="#333" 
            BorderThickness="1,0,0,0"
            ZIndex="50">
      <Grid RowDefinitions="Auto,*">
        <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="12">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBlock Text="PLAYLIST" FontWeight="Bold" FontSize="14" Foreground="#4A90E2" VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="iconBtn" Click="OnToggleSortClicked" Padding="8,4" Margin="0">
              <TextBlock x:Name="SortIconText" Text="↓ A-Z" FontSize="11" FontWeight="Bold" Foreground="#A0A0A0" />
            </Button>
          </Grid>
        </Border>

        <ListBox Grid.Row="1" ItemsSource="{Binding Playlist}" Background="Transparent" SelectionChanged="OnPlaylistSelectionChanged">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="12,8" />
              <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="#1A1A1A" />
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="#252525" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:PlaylistItem">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Background="Transparent">
                <TextBlock Grid.Column="0" Text="▶" Foreground="#4A90E2" IsVisible="{Binding IsPlaying}" VerticalAlignment="Center" Width="14" FontSize="10" />
                <TextBlock Grid.Column="0" Text="" IsVisible="{Binding !IsPlaying}" Width="14" />
                
                <TextBlock Grid.Column="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="13" />
                
                <TextBlock Grid.Column="2" Text="{Binding DurationText}" Foreground="#888" FontSize="12" FontFamily="Courier New" VerticalAlignment="Center" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Panel>
</Window>
