<Styles x:Class="MidiPlayer.App.Styles.Skins.ModernDarkStyles"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <FontFamily x:Key="Theme.UiFontFamily">Segoe UI, Inter, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="Theme.MonoFontFamily">Cascadia Mono, Consolas, Courier New, monospace</FontFamily>

    <CornerRadius x:Key="Theme.ButtonCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="Theme.InputCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="Theme.SurfaceCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="Theme.PopupCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="Theme.PillCornerRadius">999</CornerRadius>
    <CornerRadius x:Key="Theme.RoundButtonCornerRadius">18</CornerRadius>
    <CornerRadius x:Key="Theme.PlayPauseButtonCornerRadius">24</CornerRadius>
    <CornerRadius x:Key="Theme.SideToggleCornerRadius">8,0,0,8</CornerRadius>

    <SolidColorBrush x:Key="Theme.WindowBackgroundBrush" Color="#101010" />
    <SolidColorBrush x:Key="Theme.SurfaceBrush" Color="#181818" />
    <SolidColorBrush x:Key="Theme.SurfaceBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="Theme.VisualizerBackgroundBrush" Color="#0C1119" />
    <SolidColorBrush x:Key="Theme.VisualizerBorderBrush" Color="#1E2A38" />
    <SolidColorBrush x:Key="Theme.PopupBackgroundBrush" Color="#111111" />
    <SolidColorBrush x:Key="Theme.PopupBorderBrush" Color="#3A74B0" />
    <SolidColorBrush x:Key="Theme.SidebarBackgroundBrush" Color="#121212" />
    <SolidColorBrush x:Key="Theme.SidebarBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="Theme.PillBackgroundBrush" Color="#171717" />
    <SolidColorBrush x:Key="Theme.PillBorderBrush" Color="#2F2F2F" />
    <SolidColorBrush x:Key="Theme.AccentPillBackgroundBrush" Color="#13283E" />
    <SolidColorBrush x:Key="Theme.AccentPillBorderBrush" Color="#3A74B0" />

    <SolidColorBrush x:Key="Theme.ForegroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Theme.MutedForegroundBrush" Color="#A0A0A0" />
    <SolidColorBrush x:Key="Theme.SubtleForegroundBrush" Color="#888888" />
    <SolidColorBrush x:Key="Theme.HintForegroundBrush" Color="#6D7C8C" />
    <SolidColorBrush x:Key="Theme.DimForegroundBrush" Color="#666666" />
    <SolidColorBrush x:Key="Theme.AccentBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.SecondaryAccentForegroundBrush" Color="#B6D6F8" />
    <SolidColorBrush x:Key="Theme.AccentMutedForegroundBrush" Color="#5D88B4" />
    <SolidColorBrush x:Key="Theme.DisabledForegroundBrush" Color="#8091A2" />
    <SolidColorBrush x:Key="Theme.ListItemSelectedForegroundBrush" Color="#E0E0E0" />

    <SolidColorBrush x:Key="Theme.ButtonBackgroundBrush" Color="#202020" />
    <SolidColorBrush x:Key="Theme.ButtonBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="Theme.ButtonForegroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Theme.ButtonHoverBackgroundBrush" Color="#2A2A2A" />
    <SolidColorBrush x:Key="Theme.ButtonPressedBackgroundBrush" Color="#343434" />

    <SolidColorBrush x:Key="Theme.PrimaryButtonBackgroundBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.PrimaryButtonBorderBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.PrimaryButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Theme.SecondaryButtonBackgroundBrush" Color="#343434" />
    <SolidColorBrush x:Key="Theme.SecondaryButtonBorderBrush" Color="#343434" />
    <SolidColorBrush x:Key="Theme.SecondaryButtonForegroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Theme.CompactButtonBackgroundBrush" Color="#404040" />
    <SolidColorBrush x:Key="Theme.CompactButtonBorderBrush" Color="#404040" />
    <SolidColorBrush x:Key="Theme.CompactButtonForegroundBrush" Color="#E0E0E0" />

    <SolidColorBrush x:Key="Theme.IconButtonBackgroundBrush" Color="#151515" />
    <SolidColorBrush x:Key="Theme.IconButtonBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="Theme.IconButtonForegroundBrush" Color="#C8D7E6" />
    <SolidColorBrush x:Key="Theme.IconButtonHoverBackgroundBrush" Color="#303030" />

    <SolidColorBrush x:Key="Theme.ActionButtonBackgroundBrush" Color="#163553" />
    <SolidColorBrush x:Key="Theme.ActionButtonBorderBrush" Color="#3A74B0" />
    <SolidColorBrush x:Key="Theme.ActionButtonForegroundBrush" Color="#DCEEFF" />

    <SolidColorBrush x:Key="Theme.ChainButtonBackgroundBrush" Color="#1C1C1C" />
    <SolidColorBrush x:Key="Theme.ChainButtonBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="Theme.ChainButtonForegroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Theme.ChainPrimaryButtonBackgroundBrush" Color="#202A36" />
    <SolidColorBrush x:Key="Theme.ChainPrimaryButtonBorderBrush" Color="#3A74B0" />
    <SolidColorBrush x:Key="Theme.ChainPrimaryButtonForegroundBrush" Color="#DCEEFF" />
    <SolidColorBrush x:Key="Theme.ChainDangerButtonBackgroundBrush" Color="#261516" />
    <SolidColorBrush x:Key="Theme.ChainDangerButtonBorderBrush" Color="#7A3B42" />
    <SolidColorBrush x:Key="Theme.ChainDangerButtonForegroundBrush" Color="#F1D1D3" />

    <SolidColorBrush x:Key="Theme.InputBackgroundBrush" Color="#171717" />
    <SolidColorBrush x:Key="Theme.InputBorderBrush" Color="#2F2F2F" />
    <SolidColorBrush x:Key="Theme.InputForegroundBrush" Color="#E0E0E0" />

    <SolidColorBrush x:Key="Theme.ListItemHoverBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="Theme.ListItemSelectedBrush" Color="#252525" />

    <SolidColorBrush x:Key="Theme.ToggleActiveBackgroundBrush" Color="#214B75" />
    <SolidColorBrush x:Key="Theme.ToggleActiveBorderBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.ToggleActiveForegroundBrush" Color="#DCEEFF" />
    <SolidColorBrush x:Key="Theme.TogglePreparedBackgroundBrush" Color="#16293B" />
    <SolidColorBrush x:Key="Theme.TogglePreparedBorderBrush" Color="#3B6288" />
    <SolidColorBrush x:Key="Theme.TogglePreparedForegroundBrush" Color="#B8D3EC" />
    <SolidColorBrush x:Key="Theme.ToggleInactiveBackgroundBrush" Color="#171717" />
    <SolidColorBrush x:Key="Theme.ToggleInactiveBorderBrush" Color="#2F2F2F" />
    <SolidColorBrush x:Key="Theme.ToggleInactiveForegroundBrush" Color="#A0A0A0" />
    <SolidColorBrush x:Key="Theme.BadgeActiveBackgroundBrush" Color="#13283E" />
    <SolidColorBrush x:Key="Theme.BadgeActiveBorderBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.BadgeActiveForegroundBrush" Color="#DCEEFF" />
    <SolidColorBrush x:Key="Theme.BadgeStandbyBackgroundBrush" Color="#161F29" />
    <SolidColorBrush x:Key="Theme.BadgeStandbyBorderBrush" Color="#3B6288" />
    <SolidColorBrush x:Key="Theme.BadgeStandbyForegroundBrush" Color="#B8D3EC" />

    <SolidColorBrush x:Key="Theme.PlayPauseButtonBackgroundBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.PlayPauseButtonBorderBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.PlayPauseButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Theme.SideToggleBackgroundBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="Theme.SideToggleBorderBrush" Color="#333333" />
    <SolidColorBrush x:Key="Theme.SideToggleForegroundBrush" Color="#888888" />

    <SolidColorBrush x:Key="Theme.ControlOutlineBrush" Color="#111111" />
    <SolidColorBrush x:Key="Theme.PianoWhiteKeyBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Theme.PianoBlackKeyBrush" Color="#202020" />
    <SolidColorBrush x:Key="Theme.ChannelMonitorTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Theme.ChannelMonitorMutedTextBrush" Color="#696969" />
    <SolidColorBrush x:Key="Theme.ChannelDefaultTextBrush" Color="#D7DEE6" />
    <SolidColorBrush x:Key="Theme.ChannelNeutralCurrentTextBrush" Color="#DCEEFF" />
    <SolidColorBrush x:Key="Theme.ChannelInactiveBrush" Color="#303030" />
    <SolidColorBrush x:Key="Theme.ChannelMutedBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="Theme.ChannelFocusBackgroundBrush" Color="#16293B" />
    <SolidColorBrush x:Key="Theme.ChannelNeutralActiveBackgroundBrush" Color="#132131" />

    <Color x:Key="Theme.PianoRollBackgroundTopColor">#111926</Color>
    <Color x:Key="Theme.PianoRollBackgroundBottomColor">#090D14</Color>
    <SolidColorBrush x:Key="Theme.PianoRollWhiteLaneBrush" Color="#101723" />
    <SolidColorBrush x:Key="Theme.PianoRollBlackLaneBrush" Color="#0A111C" />
    <SolidColorBrush x:Key="Theme.PianoRollTextBrush" Color="#8FA4BB" />
    <SolidColorBrush x:Key="Theme.PianoRollEmptyStateBrush" Color="#6E8094" />
    <SolidColorBrush x:Key="Theme.PianoRollLaneBorderBrush" Color="#172130" />
    <SolidColorBrush x:Key="Theme.PianoRollTimeGridBrush" Color="#223249" />
    <SolidColorBrush x:Key="Theme.PianoRollHitLineBrush" Color="#EAF6FF" />
    <Color x:Key="Theme.PianoRollHitGlowColor">#60B8DDFF</Color>

    <SolidColorBrush x:Key="Theme.LoopTimelineSeekLaneBrush" Color="#202020" />
    <SolidColorBrush x:Key="Theme.LoopTimelineFullLoopBrush" Color="#162B3E" />
    <SolidColorBrush x:Key="Theme.LoopTimelineSelectionBrush" Color="#24496F" />
    <SolidColorBrush x:Key="Theme.LoopTimelineSelectionStandbyBrush" Color="#1B3248" />
    <SolidColorBrush x:Key="Theme.LoopTimelineProgressBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.LoopTimelineHandleBrush" Color="#DCEEFF" />
    <SolidColorBrush x:Key="Theme.LoopTimelinePlayheadBrush" Color="#DCEEFF" />
    <SolidColorBrush x:Key="Theme.LoopTimelineLaneBorderBrush" Color="#303030" />
    <SolidColorBrush x:Key="Theme.LoopTimelineSelectionBorderBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="Theme.LoopTimelineSelectionStandbyBorderBrush" Color="#3B5A78" />

    <Color x:Key="Theme.SpectrumBackgroundTopColor">#13243B</Color>
    <Color x:Key="Theme.SpectrumBackgroundBottomColor">#0A1321</Color>
    <Color x:Key="Theme.SpectrumGridMajorColor">#2A4364</Color>
    <Color x:Key="Theme.SpectrumGridMinorColor">#1B2B44</Color>
    <Color x:Key="Theme.SpectrumZeroLineColor">#95B9E6</Color>
    <Color x:Key="Theme.SpectrumBarsColor">#77B8FF</Color>
    <Color x:Key="Theme.SpectrumResponseFillColor">#B7ECFF</Color>
    <Color x:Key="Theme.SpectrumResponseLineColor">#BFE8FF</Color>
    <Color x:Key="Theme.SpectrumReadoutMutedColor">#61758C</Color>
    <Color x:Key="Theme.SpectrumPanelBorderColor">#23384F</Color>
    <Color x:Key="Theme.SpectrumPanelTextColor">#88A6C8</Color>
    <Color x:Key="Theme.SpectrumAxisTextColor">#9AB7D8</Color>
    <Color x:Key="Theme.SpectrumReadoutOverlayColor">#1C0A1626</Color>
    <Color x:Key="Theme.SpectrumDisabledOverlayColor">#6E050A10</Color>
    <Color x:Key="Theme.SpectrumGlyphInactiveColor">#D2A6C8</Color>
    <Color x:Key="Theme.SpectrumHandleTextColor">#D2A6C8</Color>
  </Styles.Resources>
</Styles>
